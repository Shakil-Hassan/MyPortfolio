@page "/"
@inject Portfolio.Client.Services.PortfolioService PortfolioData
@using Portfolio.Client.Models

<section class="min-h-[70vh] flex flex-col justify-center px-6 md:px-24">
    <h1 class="font-['Bebas_Neue'] text-7xl md:text-[100px] leading-none mb-4">
        BUILDING <span class="text-transparent" style="-webkit-text-stroke: 1px #00ff88">GAMES</span><br />
        & SYSTEMS
    </h1>
    <p class="text-[#6b6b8a] max-w-xl">3+ years bridging technical complexity and creative vision.</p>
</section>

<section class="px-6 md:px-24 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        @foreach (var project in PortfolioData.GetProjects()) {
            <div class="bg-[#13131f] border border-white/5 overflow-hidden group hover:border-[#00ff88]/40 transition-all">
                <div class="h-48 bg-cover bg-center" style="background-image: url('@project.ImageUrl'), url('https://placehold.co/600x400?text=No+Preview')"></div>
                <div class="p-6">
                    <div class="text-[10px] text-[#00ff88] uppercase tracking-widest mb-2">@project.Engine // @project.Category</div>
                    <h3 class="text-2xl font-['Bebas_Neue'] mb-4">@project.Title</h3>
                    <p class="text-[#6b6b8a] text-sm font-light">@project.Description</p>
                </div>
            </div>
        }
    </div>
</section>