@page "/"
@inject Portfolio.Client.Services.PortfolioService PortfolioData
@using Portfolio.Client.Models
@inject IJSRuntime JS
@implements IDisposable

<!-- HERO -->
<section class="relative min-h-screen flex flex-col justify-center px-6 md:px-24 overflow-hidden pb-32">
    <div class="hero-grid"></div>
    <div class="orb1 absolute w-[600px] h-[600px] rounded-full pointer-events-none -top-48 -right-24"
         style="background:radial-gradient(circle,rgba(0,255,136,0.12) 0%,transparent 70%);filter:blur(120px)"></div>
    <div class="orb2 absolute w-[400px] h-[400px] rounded-full pointer-events-none bottom-0 -left-24"
         style="background:radial-gradient(circle,rgba(124,58,237,0.15) 0%,transparent 70%);filter:blur(120px)"></div>

    <div class="relative z-10">
        <div class="anim-fadeup-1 inline-flex items-center gap-2 mb-8 w-fit
                    font-['Space_Mono'] text-[11px] uppercase tracking-widest text-[#00ff88]
                    bg-[#00ff88]/[0.07] border border-[#00ff88]/20 px-4 py-2">
            <span class="status-dot w-1.5 h-1.5 rounded-full bg-[#00ff88]"></span>
            @_c.HeroStatus
        </div>
        <div class="anim-fadeup-1 flex items-center gap-3 mb-6
                    font-['Space_Mono'] text-xs text-[#00ff88] tracking-[0.3em] uppercase">
            <span class="inline-block w-10 h-px bg-[#00ff88]"></span>
            @_c.HeroEyebrow
        </div>
        <h1 class="anim-fadeup-2 font-['Bebas_Neue'] leading-[0.85] tracking-tight mb-4"
            style="font-size:clamp(72px,12vw,160px)">
            @_c.HeroHeadline1 <span style="-webkit-text-stroke:1px #00ff88;color:transparent">@_c.HeroHeadline2</span><br />
            @_c.HeroHeadline3
        </h1>
        <p class="anim-fadeup-3 font-['Bebas_Neue'] text-[#6b6b8a] tracking-widest uppercase mb-10"
           style="font-size:clamp(24px,4vw,52px)">
            @_c.HeroSubtitle
        </p>
        <p class="anim-fadeup-4 max-w-xl text-[#6b6b8a] text-lg font-light leading-relaxed mb-12">
            @_c.HeroDescription
        </p>
        <div class="anim-fadeup-5 flex flex-wrap gap-6 items-center">
            <a href="#contact"
               class="btn-primary relative overflow-hidden bg-[#00ff88] text-[#0a0a0f]
                      font-['Space_Mono'] font-bold text-xs uppercase px-10 py-5
                      hover:shadow-[0_0_40px_rgba(0,255,136,0.3)] hover:-translate-y-0.5 transition-all">
                @_c.HeroCtaPrimary
            </a>
            <a href="#experience"
               class="font-['Space_Mono'] text-xs tracking-widest uppercase text-[#e8e8f0]
                      border-b border-[#6b6b8a] pb-1 hover:text-[#00ff88] hover:border-[#00ff88] transition-all">
                @_c.HeroCtaSecondary
            </a>
            <div class="flex gap-8 ml-4">
                @foreach (var stat in _c.HeroStats)
                {
                    <div class="text-right">
                        <span class="block font-['Bebas_Neue'] text-4xl text-[#00ff88] leading-none">@stat.Value</span>
                        <span class="font-['Space_Mono'] text-[9px] text-[#6b6b8a] uppercase tracking-widest">@stat.Label</span>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- MARQUEE -->
<div class="overflow-hidden border-y border-white/5 py-4 bg-[#13131f]/50">
    <div class="marquee-track">
        @foreach (var item in _c.MarqueeItems.Concat(_c.MarqueeItems))
        {
            <span class="font-['Bebas_Neue'] text-2xl text-[#6b6b8a] px-10 tracking-[0.2em] whitespace-nowrap">
                <span class="text-[#00ff88] mr-10">✦</span>@item
            </span>
        }
    </div>
</div>

<!-- PROJECTS -->
<section id="projects" class="px-6 md:px-24 py-32">
    <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-[#00ff88]"></div>
        <span class="font-['Space_Mono'] text-[#00ff88] text-[10px] tracking-[0.3em] uppercase">Deployment Log</span>
    </div>
    <h2 class="reveal font-['Bebas_Neue'] mb-20 tracking-wide uppercase"
        style="font-size:clamp(40px,8vw,100px)">
        Active <span style="-webkit-text-stroke:1px #00ff88;color:transparent">Records</span>
    </h2>

    @if (_loading)
    {
        <div class="font-['Space_Mono'] text-[#00ff88] text-xs tracking-widest animate-pulse py-20 text-center">
            LOADING_RECORDS...
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1">
            @foreach (var project in PortfolioData.GetProjects())
            {
                var isExpanded = _expandedCards.Contains(project.Id);
                var shortDesc  = project.Description.Length > 120
                                 ? project.Description[..120].TrimEnd() + "…"
                                 : project.Description;
                <div class="project-card group relative bg-[#13131f] border border-white/5 p-8 transition-all hover:border-[#00ff88]/30">
                    <div class="absolute top-0 left-0 w-full h-px bg-[#00ff88] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
                    <div class="aspect-video mb-8 overflow-hidden bg-[#0a0a0f] border border-white/5">
                        @if (!string.IsNullOrEmpty(project.VideoUrl) && project.UseVideoThumbnail)
                        {
                            <video src="@project.VideoUrl" autoplay muted loop playsinline
                                   class="w-full h-full object-cover transition-all duration-700"
                                   onerror="this.poster='https://placehold.co/600x400/13131f/6b6b8a?text=NO+VIDEO'" />
                        }
                        else
                        {
                            <img src="@project.ImageUrl"
                                 class="w-full h-full object-cover transition-all duration-700"
                                 onerror="this.src='https://placehold.co/600x400/13131f/6b6b8a?text=NO+IMAGE'" />
                        }
                    </div>
                    <div class="font-['Space_Mono'] text-[10px] text-[#00ff88] uppercase tracking-widest mb-3">
                        @project.Engine // @project.Category
                    </div>
                    <h3 class="font-['Bebas_Neue'] text-3xl mb-4 tracking-wider">@project.Title</h3>
                    <p class="text-[#6b6b8a] text-sm leading-relaxed mb-4 font-light">
                        @(isExpanded ? project.Description : shortDesc)
                    </p>
                    @if (project.Description.Length > 120)
                    {
                        <button @onclick="() => ToggleExpand(project.Id)"
                                class="font-['Space_Mono'] text-[9px] uppercase tracking-widest text-[#6b6b8a]
                                       hover:text-[#00ff88] transition-colors mb-6 block">
                            @(isExpanded ? "[ Collapse ]" : "[ Read More ]")
                        </button>
                    }
                    else
                    {
                        <div class="mb-8"></div>
                    }
                    <div class="flex gap-6">
                        <a href="#" class="font-['Space_Mono'] text-[10px] uppercase text-[#6b6b8a] hover:text-white transition-colors">[ Source ]</a>
                        <a href="/project/@project.Id" class="font-['Space_Mono'] text-[10px] uppercase text-[#00ff88] hover:underline transition-colors">[ Execute ]</a>
                    </div>
                </div>
            }
        </div>
    }
</section>

<!-- PUBLISHED GAMES -->
@if (_c.PublishedGames.Any())
{
    <section id="published" class="px-6 md:px-24 py-32 border-t border-white/5">
        <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 bg-[#00ff88]"></div>
            <span class="font-['Space_Mono'] text-[#00ff88] text-[10px] tracking-[0.3em] uppercase">Shipped Titles</span>
        </div>
        <h2 class="reveal font-['Bebas_Neue'] mb-16 tracking-wide uppercase" style="font-size:clamp(40px,8vw,100px)">
            Published <span style="-webkit-text-stroke:1px #00ff88;color:transparent">Games</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var game in _c.PublishedGames)
            {
                <div class="reveal bg-[#13131f] border border-white/5 p-8 hover:border-[#00ff88]/30 transition-all">
                    <h3 class="font-['Bebas_Neue'] text-2xl tracking-wider mb-3">@game.Title</h3>
                    <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mb-6">@game.Engine</p>
                    <div class="flex flex-wrap gap-3 mb-6">
                        @foreach (var platform in game.Platforms)
                        {
                            <span class="font-['Space_Mono'] text-[9px] px-3 py-1.5 uppercase tracking-widest bg-[#00ff88]/[0.05] border border-[#00ff88]/15 text-[#00ff88]">
                                @platform
                            </span>
                        }
                    </div>
                    <div class="flex flex-col gap-2">
                        @if (!string.IsNullOrEmpty(game.AppStoreUrl))
                        {
                            <a href="@game.AppStoreUrl" target="_blank" class="font-['Space_Mono'] text-[10px] uppercase text-[#6b6b8a] hover:text-[#00ff88] transition-colors">🍎 App Store</a>
                        }
                        @if (!string.IsNullOrEmpty(game.PlayStoreUrl))
                        {
                            <a href="@game.PlayStoreUrl" target="_blank" class="font-['Space_Mono'] text-[10px] uppercase text-[#6b6b8a] hover:text-[#00ff88] transition-colors">🤖 Play Store</a>
                        }
                        @if (!string.IsNullOrEmpty(game.ItchIoUrl))
                        {
                            <a href="@game.ItchIoUrl" target="_blank" class="font-['Space_Mono'] text-[10px] uppercase text-[#6b6b8a] hover:text-[#00ff88] transition-colors">🎮 itch.io</a>
                        }
                        @if (!string.IsNullOrEmpty(game.SteamUrl))
                        {
                            <a href="@game.SteamUrl" target="_blank" class="font-['Space_Mono'] text-[10px] uppercase text-[#6b6b8a] hover:text-[#00ff88] transition-colors">⚙ Steam</a>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
}

<!-- ENGINE BREAKDOWN -->
@if (_c.EngineStats.Any())
{
    <section class="px-6 md:px-24 py-32 border-t border-white/5">
        <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 bg-[#00ff88]"></div>
            <span class="font-['Space_Mono'] text-[#00ff88] text-[10px] tracking-[0.3em] uppercase">Engine Expertise</span>
        </div>
        <h2 class="reveal font-['Bebas_Neue'] mb-16 tracking-wide uppercase" style="font-size:clamp(40px,8vw,100px)">
            Engine <span style="-webkit-text-stroke:1px #00ff88;color:transparent">Breakdown</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
            @foreach (var engine in _c.EngineStats)
            {
                <div class="reveal">
                    <div class="flex items-end gap-4 mb-4">
                        <h3 class="font-['Bebas_Neue'] text-4xl tracking-wider text-[#00ff88]">@engine.ProjectCount</h3>
                        <div class="flex-1">
                            <div class="font-['Bebas_Neue'] text-2xl tracking-wider mb-1">@engine.Engine</div>
                            <div class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest">Projects</div>
                        </div>
                    </div>
                    <p class="text-[#6b6b8a] text-sm leading-relaxed">@engine.Description</p>
                </div>
            }
        </div>
    </section>
}

<!-- TEAM EXPERIENCE -->
@if (_c.TeamExperiences.Any())
{
    <section class="px-6 md:px-24 py-32 border-t border-white/5">
        <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 bg-[#00ff88]"></div>
            <span class="font-['Space_Mono'] text-[#00ff88] text-[10px] tracking-[0.3em] uppercase">Collaboration</span>
        </div>
        <h2 class="reveal font-['Bebas_Neue'] mb-16 tracking-wide uppercase" style="font-size:clamp(40px,8vw,100px)">
            Team <span style="-webkit-text-stroke:1px #00ff88;color:transparent">Experience</span>
        </h2>

        <div class="grid grid-cols-1 gap-8">
            @foreach (var team in _c.TeamExperiences)
            {
                <div class="reveal grid grid-cols-1 md:grid-cols-4 gap-6 p-8 bg-[#13131f] border border-white/5 hover:border-[#00ff88]/20 transition-all">
                    <div>
                        <div class="font-['Space_Mono'] text-[9px] text-[#6b6b8a] uppercase tracking-widest mb-2">Period</div>
                        <div class="font-['Bebas_Neue'] text-lg tracking-wider">@team.Period</div>
                    </div>
                    <div>
                        <div class="font-['Space_Mono'] text-[9px] text-[#6b6b8a] uppercase tracking-widest mb-2">Studio</div>
                        <div class="font-['Bebas_Neue'] text-lg tracking-wider">@team.Studio</div>
                    </div>
                    <div>
                        <div class="font-['Space_Mono'] text-[9px] text-[#6b6b8a] uppercase tracking-widest mb-2">Team Size</div>
                        <div class="font-['Bebas_Neue'] text-2xl text-[#00ff88]">@team.TeamSize</div>
                    </div>
                    <div>
                        <div class="font-['Space_Mono'] text-[9px] text-[#6b6b8a] uppercase tracking-widest mb-3">Roles & Tools</div>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var role in team.Roles.Take(2))
                            {
                                <span class="font-['Space_Mono'] text-[9px] px-2 py-1 bg-[#00ff88]/[0.05] border border-[#00ff88]/15 text-[#00ff88] uppercase tracking-widest">@role</span>
                            }
                            @foreach (var tool in team.CollaborationTools.Take(2))
                            {
                                <span class="font-['Space_Mono'] text-[9px] px-2 py-1 bg-[#7c3aed]/[0.05] border border-[#7c3aed]/15 text-[#7c3aed] uppercase tracking-widest">@tool</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<!-- ABOUT -->
<section id="about" class="px-6 md:px-24 py-32 border-t border-white/5">
    <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-[#00ff88]"></div>
        <span class="font-['Space_Mono'] text-[#00ff88] text-[10px] tracking-[0.3em] uppercase">About</span>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
        <div class="reveal">
            <h2 class="font-['Bebas_Neue'] mb-10" style="font-size:clamp(40px,6vw,80px)">
                @_c.AboutHeadline<br />
                <span style="-webkit-text-stroke:1px #00ff88;color:transparent">@_c.AboutSubheadline</span>
            </h2>
            @foreach (var para in _c.AboutParagraphs)
            {
                <p class="text-[#6b6b8a] leading-relaxed mb-6 font-light">@((MarkupString)para)</p>
            }
            <div class="flex flex-wrap gap-3 mt-8">
                @foreach (var tag in _c.AboutTags)
                {
                    <span class="px-4 py-2 border border-white/10 bg-white/5 font-['Space_Mono'] text-[10px]
                                 text-[#6b6b8a] uppercase tracking-widest
                                 hover:border-[#00ff88] hover:text-[#00ff88] transition-all cursor-default">@tag</span>
                }
            </div>
        </div>
        <div class="reveal expertise-list" style="transition-delay:0.2s">
            <div class="flex items-center gap-3 mb-8">
                <div class="h-px w-6 bg-[#00ff88]"></div>
                <span class="font-['Space_Mono'] text-[#00ff88] text-[10px] tracking-[0.3em] uppercase">Core Expertise</span>
            </div>
            @foreach (var bar in _c.ExpertiseBars)
            {
                <div class="mb-6">
                    <div class="flex justify-between mb-2">
                        <span class="font-['Space_Mono'] text-xs tracking-widest uppercase text-[#e8e8f0]">@bar.Name</span>
                        <span class="font-['Space_Mono'] text-xs text-[#00ff88]">@bar.Pct%</span>
                    </div>
                    <div class="h-px bg-white/[0.07] relative overflow-visible">
                        <div class="exp-bar" data-width="@bar.Pct"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- HIGHLIGHTS STRIP -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-px reveal">
    @foreach (var h in _c.Highlights)
    {
        <div class="highlight-card relative overflow-hidden bg-[#13131f] border border-white/[0.07] p-10
                    hover:bg-[#7c3aed]/[0.05] hover:border-[#7c3aed]/20 transition-all">
            <div class="font-['Bebas_Neue'] text-6xl leading-none text-[#00ff88] mb-2">
                @h.Number<span class="text-3xl text-[#6b6b8a]">@h.Suffix</span>
            </div>
            <div class="font-['Space_Mono'] text-[11px] tracking-[0.15em] uppercase text-[#6b6b8a]">@h.Label</div>
        </div>
    }
</div>

<!-- EXPERIENCE -->
<section id="experience" class="px-6 md:px-24 py-32 border-t border-white/5">
    <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-[#00ff88]"></div>
        <span class="font-['Space_Mono'] text-[#00ff88] text-[10px] tracking-[0.3em] uppercase">Career</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-20 items-start">
        <div>
            <h2 class="reveal font-['Bebas_Neue'] leading-none mb-14" style="font-size:clamp(40px,6vw,80px)">
                Work<br />History
            </h2>
            <div class="timeline">
                @foreach (var job in _c.Jobs)
                {
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="flex gap-4 items-center mb-2">
                            <span class="font-['Space_Mono'] text-[11px] text-[#00ff88] tracking-widest">@job.Date</span>
                            <span class="font-['Space_Mono'] text-[11px] text-[#6b6b8a] tracking-widest">@job.Company</span>
                        </div>
                        <div class="font-['Bebas_Neue'] text-3xl tracking-wide text-[#e8e8f0] mb-3">@job.Role</div>
                        <p class="text-[15px] text-[#6b6b8a] font-light leading-[1.8] mb-4">@job.Desc</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var tag in job.Tags)
                            {
                                <span class="font-['Space_Mono'] text-[10px] tracking-widest uppercase px-3 py-1
                                             bg-[#00ff88]/[0.05] border border-[#00ff88]/15 text-[#00ff88]">@tag</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
        <div>
            <h2 class="reveal font-['Bebas_Neue'] leading-none mb-14"
                style="font-size:clamp(40px,6vw,80px);transition-delay:0.2s">
                Key<br />Deliverables
            </h2>
            <div class="flex flex-col gap-4">
                @foreach (var d in _c.Deliverables)
                {
                    <div class="highlight-card reveal relative overflow-hidden bg-[#13131f]
                                border border-white/[0.07] p-7
                                hover:bg-[#7c3aed]/[0.05] hover:border-[#7c3aed]/20 transition-all">
                        <div class="font-['Space_Mono'] text-[11px] tracking-[0.15em] uppercase text-[#00ff88] mb-3">@d.Label</div>
                        <div class="text-[15px] text-[#e8e8f0] font-medium mb-2">@d.Title</div>
                        <div class="text-[13px] text-[#6b6b8a] font-light leading-[1.7]">@d.Desc</div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section id="contact"
         class="contact-section relative overflow-hidden text-center
                bg-[#13131f] border-y border-white/[0.07] px-6 py-40">
    <h2 class="reveal font-['Bebas_Neue'] leading-none mb-8" style="font-size:clamp(48px,8vw,100px)">
        @((MarkupString)_c.ContactTitle.Replace("TOGETHER",
            "<span style=\"-webkit-text-stroke:1px #00ff88;color:transparent\">TOGETHER</span>"))
    </h2>
    <p class="reveal text-[#6b6b8a] mb-12 max-w-md mx-auto font-light" style="transition-delay:0.2s">
        @_c.ContactSub
    </p>
    <div class="reveal flex flex-wrap justify-center gap-8" style="transition-delay:0.3s">
        <a href="mailto:@_c.ContactEmail"
           class="font-['Space_Mono'] text-xs border border-white/10 px-10 py-5 uppercase
                  hover:border-[#00ff88] hover:text-[#00ff88] hover:shadow-[0_0_30px_rgba(0,255,136,0.12)]
                  hover:-translate-y-0.5 transition-all tracking-widest">✉ Email Me</a>
        <a href="@_c.ContactLinkedIn" target="_blank"
           class="font-['Space_Mono'] text-xs border border-white/10 px-10 py-5 uppercase
                  hover:border-[#00ff88] hover:text-[#00ff88] hover:shadow-[0_0_30px_rgba(0,255,136,0.12)]
                  hover:-translate-y-0.5 transition-all tracking-widest">in LinkedIn</a>
        <a href="@_c.ContactGithub" target="_blank"
           class="font-['Space_Mono'] text-xs border border-white/10 px-10 py-5 uppercase
                  hover:border-[#00ff88] hover:text-[#00ff88] hover:shadow-[0_0_30px_rgba(0,255,136,0.12)]
                  hover:-translate-y-0.5 transition-all tracking-widest">⌥ GitHub</a>
        <a href="@_c.ContactResume"
           class="font-['Space_Mono'] text-xs border border-white/10 px-10 py-5 uppercase
                  hover:border-[#00ff88] hover:text-[#00ff88] hover:shadow-[0_0_30px_rgba(0,255,136,0.12)]
                  hover:-translate-y-0.5 transition-all tracking-widest">↓ Resume PDF</a>
    </div>
</section>

@code {
    private bool        _loading      = true;
    private SiteContent _c            = new();
    private HashSet<string> _expandedCards = new();

    private void ToggleExpand(string id)
    {
        if (_expandedCards.Contains(id)) _expandedCards.Remove(id);
        else _expandedCards.Add(id);
    }

    protected override async Task OnInitializedAsync()
    {
        await PortfolioData.EnsureLoadedAsync();
        _c = PortfolioData.GetContent();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("portfolioInit");
    }

    public void Dispose() { }
}
