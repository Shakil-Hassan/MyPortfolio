@code {
    private string      _activeSection  = "projects";
    private SiteContent _c              = new();
    private bool        _saving         = false;
    private bool        _saved          = false;

    private static readonly Dictionary<string, string> _sections = new()
    {
        ["projects"]   = "01  Projects",
        ["hero"]       = "02  Hero",
        ["marquee"]    = "03  Marquee",
        ["about"]      = "04  About",
        ["highlights"] = "05  Highlights",
        ["experience"] = "06  Experience",
        ["contact"]    = "07  Contact",
    };

    private Project newProject       = new();
    private bool    isEditing        = false;
    private bool    isUploading      = false;
    private string  originalImageUrl = string.Empty;
    private string  originalVideoUrl = string.Empty;
    private string  _featuresText    = string.Empty;
    private string  _patternsText    = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await PortfolioData.EnsureLoadedAsync();
        var json = System.Text.Json.JsonSerializer.Serialize(PortfolioData.GetContent());
        _c = System.Text.Json.JsonSerializer.Deserialize<SiteContent>(json) ?? new();
    }

    private async Task SaveContent()
    {
        _saving = true; _saved = false;
        await PortfolioData.SaveContentAsync(_c);
        _saving = false; _saved = true;
        await Task.Delay(2000);
        _saved = false;
    }

    private async Task HandleImageSelected(InputFileChangeEventArgs e)
    {
        isUploading = true;
        var url = await FileUploadService.UploadFileAsync(e.File);
        if (!string.IsNullOrEmpty(url))
        {
            if (isEditing && !string.IsNullOrEmpty(newProject.ImageUrl) && newProject.ImageUrl != originalImageUrl)
                await FileUploadService.DeleteFileAsync(newProject.ImageUrl);
            newProject.ImageUrl = url;
        }
        isUploading = false;
    }

    private async Task HandleVideoSelected(InputFileChangeEventArgs e)
    {
        isUploading = true;
        var url = await FileUploadService.UploadFileAsync(e.File);
        if (!string.IsNullOrEmpty(url))
        {
            if (isEditing && !string.IsNullOrEmpty(newProject.VideoUrl) && newProject.VideoUrl != originalVideoUrl)
                await FileUploadService.DeleteFileAsync(newProject.VideoUrl);
            newProject.VideoUrl = url;
        }
        isUploading = false;
    }

    private async Task HandleProjectSubmit()
    {
        newProject.Features = _featuresText
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        newProject.DesignPatterns = _patternsText
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        if (isEditing)
        {
            if (!string.IsNullOrEmpty(originalImageUrl) && newProject.ImageUrl != originalImageUrl)
                await FileUploadService.DeleteFileAsync(originalImageUrl);
            if (!string.IsNullOrEmpty(originalVideoUrl) && newProject.VideoUrl != originalVideoUrl)
                await FileUploadService.DeleteFileAsync(originalVideoUrl);
            PortfolioData.DeleteProject(newProject.Id);
        }
        PortfolioData.AddProject(newProject);
        ResetProjectForm();
    }

    private void StartProjectEdit(Project p)
    {
        newProject = new Project {
            Id=p.Id, Title=p.Title, Engine=p.Engine, Description=p.Description,
            Category=p.Category, ImageUrl=p.ImageUrl, VideoUrl=p.VideoUrl, UseVideoThumbnail=p.UseVideoThumbnail,
            TechStack=p.TechStack, GithubUrl=p.GithubUrl, GameUrl=p.GameUrl,
            Features=new(p.Features), DesignPatterns=new(p.DesignPatterns) };
        originalImageUrl = p.ImageUrl;
        originalVideoUrl = p.VideoUrl;
        _featuresText    = string.Join("\n", p.Features);
        _patternsText    = string.Join("\n", p.DesignPatterns);
        isEditing = true;
    }

    private void CancelProjectEdit() => ResetProjectForm();

    private async Task DeleteProject(Project p)
    {
        if (!string.IsNullOrEmpty(p.ImageUrl)) await FileUploadService.DeleteFileAsync(p.ImageUrl);
        if (!string.IsNullOrEmpty(p.VideoUrl)) await FileUploadService.DeleteFileAsync(p.VideoUrl);
        PortfolioData.DeleteProject(p.Id);
    }

    private void ResetProjectForm()
    {
        newProject = new(); originalImageUrl = string.Empty; originalVideoUrl = string.Empty;
        _featuresText = string.Empty; _patternsText = string.Empty; isEditing = false;
    }
}
