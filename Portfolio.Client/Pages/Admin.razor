@page "/admin"
@inject Portfolio.Client.Services.PortfolioService PortfolioData
@using Portfolio.Client.Models

<section class="px-6 md:px-24 py-12">
    <h2 class="font-['Bebas_Neue'] text-5xl mb-8 tracking-wide">SYSTEM <span class="text-[#00ff88]">ADMINISTRATION</span></h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <div class="lg:col-span-1 bg-[#13131f] border border-white/5 p-8">
            <h3 class="font-['Space_Mono'] text-[#00ff88] text-xs tracking-[0.2em] uppercase mb-6 border-b border-white/5 pb-4">Initialize New Entry</h3>
            
            <EditForm Model="newProject" OnValidSubmit="HandleSubmit" class="flex flex-col gap-4">
                <div>
                    <label class="block font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase mb-2">Project Title</label>
                    <InputText @bind-Value="newProject.Title" class="w-full bg-[#0a0a0f] border border-white/10 p-3 text-sm focus:border-[#00ff88] outline-none text-white" />
                </div>
                <div>
                    <label class="block font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase mb-2">Engine Stack</label>
                    <InputText @bind-Value="newProject.Engine" class="w-full bg-[#0a0a0f] border border-white/10 p-3 text-sm focus:border-[#00ff88] outline-none text-white" placeholder="e.g., Unity, Godot" />
                </div>
                <div>
                    <label class="block font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase mb-2">System Description</label>
                    <InputTextArea @bind-Value="newProject.Description" rows="4" class="w-full bg-[#0a0a0f] border border-white/10 p-3 text-sm focus:border-[#00ff88] outline-none text-white" />
                </div>
                
                <button type="submit" class="mt-4 bg-[#00ff88] text-[#0a0a0f] font-['Space_Mono'] font-bold text-xs uppercase tracking-widest py-4 hover:shadow-[0_0_20px_rgba(0,255,136,0.3)] transition-all">
                    Execute Override (Add)
                </button>
            </EditForm>
        </div>

        <div class="lg:col-span-2">
            <h3 class="font-['Space_Mono'] text-[#00ff88] text-xs tracking-[0.2em] uppercase mb-6 border-b border-white/5 pb-4">Active Database Records</h3>
            
            <div class="flex flex-col gap-4">
                @foreach (var project in PortfolioData.GetProjects())
                {
                    <div class="bg-[#13131f] border border-white/5 p-6 flex justify-between items-center group hover:border-white/20">
                        <div>
                            <h4 class="font-['Bebas_Neue'] text-2xl tracking-wide">@project.Title</h4>
                            <span class="font-['Space_Mono'] text-[10px] text-[#6b6b8a]">ID: @project.Id.Substring(0, 8)... // @project.Engine</span>
                        </div>
                        <button @onclick="() => DeleteEntry(project.Id)" class="text-[#ff3c6e] font-['Space_Mono'] text-[10px] uppercase tracking-widest hover:underline opacity-0 group-hover:opacity-100 transition-opacity">
                            [ Terminate ]
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private Project newProject = new Project();

    private void HandleSubmit()
    {
        if (!string.IsNullOrWhiteSpace(newProject.Title))
        {
            PortfolioData.AddProject(newProject);
            // Reset form
            newProject = new Project();
        }
    }

    private void DeleteEntry(string id)
    {
        PortfolioData.DeleteProject(id);
    }
}