@page "/admin"
@using Portfolio.Client.Models
@using Portfolio.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject PortfolioService PortfolioData
@inject IFileUploadService FileUploadService

<div class="flex min-h-screen">

    <!-- ═══════════ SIDEBAR ═══════════ -->
    <aside class="hidden lg:flex flex-col w-56 flex-shrink-0 fixed top-20 bottom-0 left-0
                  bg-[#0a0a0f] border-r border-white/5 overflow-y-auto z-40">
        <div class="p-6 border-b border-white/5">
            <div class="font-['Space_Mono'] text-[9px] text-[#6b6b8a] uppercase tracking-[0.3em]">Admin Panel</div>
        </div>
        <nav class="flex flex-col p-4 gap-1">
            @foreach (var s in _sections)
            {
                var isActive = _activeSection == s.Key;
                var btnClass = isActive
                    ? "text-[#00ff88] border-[#00ff88] bg-[#00ff88]/[0.05]"
                    : "text-[#6b6b8a] border-transparent hover:text-white hover:border-white/20";
                <button @onclick="() => _activeSection = s.Key"
                        class="text-left px-4 py-3 font-['Space_Mono'] text-[10px] uppercase tracking-widest
                               transition-all border-l-2 @btnClass">
                    @s.Value
                </button>
            }
        </nav>
    </aside>

    <!-- Mobile picker -->
    <div class="lg:hidden px-6 pt-6 w-full">
        <select @bind="_activeSection"
                class="w-full bg-[#13131f] border border-white/10 text-[#e8e8f0]
                       font-['Space_Mono'] text-xs uppercase tracking-widest px-4 py-3">
            @foreach (var s in _sections)
            {
                <option value="@s.Key">@s.Value</option>
            }
        </select>
    </div>

    <!-- ═══════════ MAIN ═══════════ -->
    <main class="flex-1 lg:ml-56 px-6 md:px-12 py-12">

        @if (_saving)
        {
            <div class="fixed top-24 right-6 z-50 font-['Space_Mono'] text-[10px] text-[#00ff88]
                        bg-[#13131f] border border-[#00ff88]/30 px-4 py-2 tracking-widest uppercase animate-pulse">
                Saving...
            </div>
        }
        @if (_saved)
        {
            <div class="fixed top-24 right-6 z-50 font-['Space_Mono'] text-[10px] text-[#00ff88]
                        bg-[#13131f] border border-[#00ff88]/30 px-4 py-2 tracking-widest uppercase">
                ✓ Saved
            </div>
        }

        <!-- ── PROJECTS ── -->
        @if (_activeSection == "projects")
        {
            <!-- Section Header -->
            <div class="mb-8">
                <h2 class="font-['Bebas_Neue'] text-5xl tracking-wide">Projects</h2>
                <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mt-1">Manage portfolio project cards</p>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-12">
                <!-- Form -->
                <div class="xl:col-span-1">
                    <div class="bg-[#13131f] border border-white/5 p-8">
                        <div class="admin-section-label mb-8">@(isEditing ? "Edit Project" : "Add Project")</div>
                        <EditForm Model="newProject" OnValidSubmit="HandleProjectSubmit" class="flex flex-col gap-5">

                            <div class="flex flex-col">
                                <label class="admin-label">Title</label>
                                <InputText @bind-Value="newProject.Title" class="admin-input" placeholder="Project Name" />
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex flex-col">
                                    <label class="admin-label">Engine</label>
                                    <InputText @bind-Value="newProject.Engine" class="admin-input" placeholder="Unity" />
                                </div>
                                <div class="flex flex-col">
                                    <label class="admin-label">Category</label>
                                    <InputText @bind-Value="newProject.Category" class="admin-input" placeholder="Tooling" />
                                </div>
                            </div>

                            <div>
                                <label class="admin-label">Image</label>
                                <div class="relative border border-white/10 p-5 bg-[#0a0a0f] hover:border-[#00ff88]/30 transition-colors">
                                    <InputFile OnChange="HandleImageSelected" class="absolute inset-0 opacity-0 cursor-pointer z-10" accept=".png,.jpg,.jpeg" />
                                    <span class="text-[10px] text-[#6b6b8a] uppercase tracking-widest block text-center">
                                        @(isUploading ? "Uploading..." : string.IsNullOrEmpty(newProject.ImageUrl) ? "Drop Image" : "✓ Image Set")
                                    </span>
                                </div>
                            </div>

                            <div>
                                <label class="admin-label">Video</label>
                                <div class="relative border border-white/10 p-5 bg-[#0a0a0f] hover:border-[#00ff88]/30 transition-colors">
                                    <InputFile OnChange="HandleVideoSelected" class="absolute inset-0 opacity-0 cursor-pointer z-10" accept=".mp4,.webm,.mov,.ogg" />
                                    <span class="text-[10px] text-[#6b6b8a] uppercase tracking-widest block text-center">
                                        @(isUploading ? "Uploading..." : string.IsNullOrEmpty(newProject.VideoUrl) ? "Drop Video" : "✓ Video Set")
                                    </span>
                                </div>
                            </div>

                            <div class="flex items-center gap-4">
                                <label class="admin-label mb-0">Thumbnail</label>
                                <InputRadioGroup @bind-Value="newProject.UseVideoThumbnail">
                                    <div class="flex gap-3">
                                        <label class="font-['Space_Mono'] text-[10px] tracking-widest">
                                            <InputRadio class="mr-1" Value="false" />
                                            Image
                                        </label>
                                        <label class="font-['Space_Mono'] text-[10px] tracking-widest">
                                            <InputRadio class="mr-1" Value="true" />
                                            Video
                                        </label>
                                    </div>
                                </InputRadioGroup>
                            </div>

                            <div class="flex flex-col">
                                <label class="admin-label">Description</label>
                                <InputTextArea @bind-Value="newProject.Description" rows="3" class="admin-input" />
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Tech Stack (comma sep)</label>
                                <InputText @bind-Value="newProject.TechStack" class="admin-input" placeholder="C#, Unity" />
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Features (one per line)</label>
                                <textarea class="admin-input" rows="3" @bind="_featuresText"></textarea>
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Design Patterns (one per line)</label>
                                <textarea class="admin-input" rows="3" @bind="_patternsText"></textarea>
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">GitHub URL</label>
                                <InputText @bind-Value="newProject.GithubUrl" class="admin-input" placeholder="https://github.com/..." />
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Demo URL</label>
                                <InputText @bind-Value="newProject.GameUrl" class="admin-input" placeholder="https://..." />
                            </div>

                            <div class="flex gap-3 pt-2">
                                <button type="submit" class="btn-admin-green flex-1">@(isEditing ? "Update" : "Add")</button>
                                @if (isEditing)
                                {
                                    <button type="button" @onclick="CancelProjectEdit" class="btn-admin-ghost">Cancel</button>
                                }
                            </div>
                        </EditForm>
                    </div>
                </div>

                <!-- Records list -->
                <div class="xl:col-span-2 flex flex-col gap-3">
                    @foreach (var p in PortfolioData.GetProjects())
                    {
                        <div class="record-card">
                            <div class="flex items-center gap-4">
                                <img src="@p.ImageUrl" class="w-20 h-14 object-cover bg-[#0a0a0f] border border-white/10 flex-shrink-0"
                                     onerror="this.src='https://placehold.co/80x56/13131f/6b6b8a?text=NA'" />
                                <div>
                                    <div class="font-['Bebas_Neue'] text-xl">@p.Title</div>
                                    <div class="font-['Space_Mono'] text-[10px] text-[#6b6b8a]">@p.Engine // @p.Category</div>
                                </div>
                            </div>
                            <div class="flex gap-6 flex-shrink-0">
                                <a href="/project/@p.Id" target="_blank" class="action-link">View</a>
                                <button @onclick="() => StartProjectEdit(p)" class="action-link green">Edit</button>
                                <button @onclick="() => DeleteProject(p)" class="action-link red">Delete</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ── HERO ── -->
        @if (_activeSection == "hero")
        {
            <div class="mb-8">
                <h2 class="font-['Bebas_Neue'] text-5xl tracking-wide">Hero Section</h2>
                <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mt-1">Edit the main landing banner</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-[#13131f] border border-white/5 p-8 flex flex-col gap-5">
                    <div class="flex flex-col"><label class="admin-label">Status Badge</label><InputText @bind-Value="_c.HeroStatus" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">Eyebrow Text</label><InputText @bind-Value="_c.HeroEyebrow" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">Headline Line 1</label><InputText @bind-Value="_c.HeroHeadline1" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">Headline Line 2 (outline)</label><InputText @bind-Value="_c.HeroHeadline2" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">Headline Line 3</label><InputText @bind-Value="_c.HeroHeadline3" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">Subtitle</label><InputText @bind-Value="_c.HeroSubtitle" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">Description</label><InputTextArea @bind-Value="_c.HeroDescription" rows="3" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">CTA Primary</label><InputText @bind-Value="_c.HeroCtaPrimary" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">CTA Secondary</label><InputText @bind-Value="_c.HeroCtaSecondary" class="admin-input" /></div>
                </div>
                <div class="bg-[#13131f] border border-white/5 p-8 flex flex-col gap-5">
                    <div class="admin-section-label">Stats</div>
                    @for (int i = 0; i < _c.HeroStats.Count; i++)
                    {
                        var idx = i;
                        <div class="flex gap-3 items-end">
                            <div class="flex flex-col flex-1">
                                <label class="admin-label">Value</label>
                                <InputText @bind-Value="_c.HeroStats[idx].Value" class="admin-input" />
                            </div>
                            <div class="flex flex-col flex-1">
                                <label class="admin-label">Label</label>
                                <InputText @bind-Value="_c.HeroStats[idx].Label" class="admin-input" />
                            </div>
                            <button @onclick="() => _c.HeroStats.RemoveAt(idx)" class="btn-admin-red px-3 py-2 self-end mb-0.5">✕</button>
                        </div>
                    }
                    <button @onclick="() => _c.HeroStats.Add(new StatItem())" class="btn-admin-ghost text-xs">+ Add Stat</button>
                </div>
            </div>

            <!-- Save Bar -->
            <div class="mt-10 pt-6 border-t border-white/5 flex items-center gap-4">
                <button @onclick="SaveContent" class="btn-admin-green">Save Changes</button>
                <span class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest">Saved to server JSON</span>
            </div>
        }

        <!-- ── MARQUEE ── -->
        @if (_activeSection == "marquee")
        {
            <div class="mb-8">
                <h2 class="font-['Bebas_Neue'] text-5xl tracking-wide">Marquee Ticker</h2>
                <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mt-1">Edit the scrolling tech tags</p>
            </div>

            <div class="bg-[#13131f] border border-white/5 p-8 max-w-2xl">
                <div class="admin-section-label mb-6">Items</div>
                @for (int i = 0; i < _c.MarqueeItems.Count; i++)
                {
                    var idx = i;
                    <div class="flex gap-3 mb-3">
                        <input class="admin-input flex-1" @bind="_c.MarqueeItems[idx]" />
                        <button @onclick="() => _c.MarqueeItems.RemoveAt(idx)" class="btn-admin-red px-3">✕</button>
                    </div>
                }
                <button @onclick="() => _c.MarqueeItems.Add(string.Empty)" class="btn-admin-ghost text-xs mt-2">+ Add Item</button>
            </div>

            <div class="mt-10 pt-6 border-t border-white/5 flex items-center gap-4">
                <button @onclick="SaveContent" class="btn-admin-green">Save Changes</button>
                <span class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest">Saved to server JSON</span>
            </div>
        }

        <!-- ── ABOUT ── -->
        @if (_activeSection == "about")
        {
            <div class="mb-8">
                <h2 class="font-['Bebas_Neue'] text-5xl tracking-wide">About Section</h2>
                <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mt-1">Edit bio, tags and expertise bars</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-[#13131f] border border-white/5 p-8 flex flex-col gap-5">
                    <div class="flex flex-col"><label class="admin-label">Headline</label><InputText @bind-Value="_c.AboutHeadline" class="admin-input" /></div>
                    <div class="flex flex-col"><label class="admin-label">Subheadline (outline)</label><InputText @bind-Value="_c.AboutSubheadline" class="admin-input" /></div>

                    <div class="admin-section-label mt-2">Paragraphs</div>
                    @for (int i = 0; i < _c.AboutParagraphs.Count; i++)
                    {
                        var idx = i;
                        <div class="flex gap-3">
                            <textarea class="admin-input flex-1" rows="3" @bind="_c.AboutParagraphs[idx]"></textarea>
                            <button @onclick="() => _c.AboutParagraphs.RemoveAt(idx)" class="btn-admin-red px-3 self-start mt-1">✕</button>
                        </div>
                    }
                    <button @onclick="() => _c.AboutParagraphs.Add(string.Empty)" class="btn-admin-ghost text-xs">+ Add Paragraph</button>

                    <div class="admin-section-label mt-2">Tech Tags</div>
                    <div class="flex flex-wrap gap-2">
                        @for (int i = 0; i < _c.AboutTags.Count; i++)
                        {
                            var idx = i;
                            <div class="flex gap-1 items-center">
                                <input class="admin-input w-24 text-xs py-2 px-2" @bind="_c.AboutTags[idx]" />
                                <button @onclick="() => _c.AboutTags.RemoveAt(idx)" class="text-[#ff3c6e] text-xs px-1">✕</button>
                            </div>
                        }
                        <button @onclick="() => _c.AboutTags.Add(string.Empty)" class="btn-admin-ghost text-xs px-3 py-2">+</button>
                    </div>
                </div>

                <div class="bg-[#13131f] border border-white/5 p-8 flex flex-col gap-5">
                    <div class="admin-section-label">Expertise Bars</div>
                    @for (int i = 0; i < _c.ExpertiseBars.Count; i++)
                    {
                        var idx = i;
                        <div class="flex gap-3 items-end">
                            <div class="flex flex-col flex-1">
                                <label class="admin-label">Skill</label>
                                <InputText @bind-Value="_c.ExpertiseBars[idx].Name" class="admin-input" />
                            </div>
                            <div class="flex flex-col w-20">
                                <label class="admin-label">%</label>
                                <input type="number" min="0" max="100" class="admin-input"
                                       value="@_c.ExpertiseBars[idx].Pct"
                                       @onchange="@(e => _c.ExpertiseBars[idx].Pct = int.TryParse(e.Value?.ToString(), out var v) ? v : 80)" />
                            </div>
                            <button @onclick="() => _c.ExpertiseBars.RemoveAt(idx)" class="btn-admin-red px-3 py-2 self-end mb-0.5">✕</button>
                        </div>
                    }
                    <button @onclick="() => _c.ExpertiseBars.Add(new ExpertiseBar())" class="btn-admin-ghost text-xs">+ Add Bar</button>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-white/5 flex items-center gap-4">
                <button @onclick="SaveContent" class="btn-admin-green">Save Changes</button>
                <span class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest">Saved to server JSON</span>
            </div>
        }

        <!-- ── HIGHLIGHTS ── -->
        @if (_activeSection == "highlights")
        {
            <div class="mb-8">
                <h2 class="font-['Bebas_Neue'] text-5xl tracking-wide">Highlights Strip</h2>
                <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mt-1">The stat cards below About</p>
            </div>

            <div class="bg-[#13131f] border border-white/5 p-8 max-w-3xl flex flex-col gap-5">
                @for (int i = 0; i < _c.Highlights.Count; i++)
                {
                    var idx = i;
                    <div class="flex gap-3 items-end">
                        <div class="flex flex-col w-24">
                            <label class="admin-label">Number</label>
                            <InputText @bind-Value="_c.Highlights[idx].Number" class="admin-input" />
                        </div>
                        <div class="flex flex-col w-16">
                            <label class="admin-label">Suffix</label>
                            <InputText @bind-Value="_c.Highlights[idx].Suffix" class="admin-input" />
                        </div>
                        <div class="flex flex-col flex-1">
                            <label class="admin-label">Label</label>
                            <InputText @bind-Value="_c.Highlights[idx].Label" class="admin-input" />
                        </div>
                        <button @onclick="() => _c.Highlights.RemoveAt(idx)" class="btn-admin-red px-3 py-2 self-end mb-0.5">✕</button>
                    </div>
                }
                <button @onclick="() => _c.Highlights.Add(new HighlightStat())" class="btn-admin-ghost text-xs">+ Add Highlight</button>
            </div>

            <div class="mt-10 pt-6 border-t border-white/5 flex items-center gap-4">
                <button @onclick="SaveContent" class="btn-admin-green">Save Changes</button>
                <span class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest">Saved to server JSON</span>
            </div>
        }

        <!-- ── EXPERIENCE ── -->
        @if (_activeSection == "experience")
        {
            <div class="mb-8">
                <h2 class="font-['Bebas_Neue'] text-5xl tracking-wide">Experience Timeline</h2>
                <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mt-1">Work history and key deliverables</p>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-2 gap-12">
                <!-- Jobs -->
                <div class="flex flex-col gap-4">
                    <div class="admin-section-label">Timeline Jobs</div>
                    @for (int i = 0; i < _c.Jobs.Count; i++)
                    {
                        var idx = i;
                        var job = _c.Jobs[idx];
                        <div class="bg-[#13131f] border border-white/5 p-6 flex flex-col gap-4">
                            <div class="grid grid-cols-2 gap-3">
                                <div class="flex flex-col">
                                    <label class="admin-label">Date</label>
                                    <InputText @bind-Value="job.Date" class="admin-input" />
                                </div>
                                <div class="flex flex-col">
                                    <label class="admin-label">Company</label>
                                    <InputText @bind-Value="job.Company" class="admin-input" />
                                </div>
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Role</label>
                                <InputText @bind-Value="job.Role" class="admin-input" />
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Description</label>
                                <InputTextArea @bind-Value="job.Desc" rows="2" class="admin-input" />
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Tags (comma sep)</label>
                                <input class="admin-input" value="@string.Join(", ", job.Tags)"
                                       @onchange="@(e => job.Tags = (e.Value ?? string.Empty).ToString()!
                                           .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                                           .ToList())" />
                            </div>
                            <button @onclick="() => _c.Jobs.RemoveAt(idx)" class="btn-admin-red text-xs self-end">Remove Job</button>
                        </div>
                    }
                    <button @onclick="() => _c.Jobs.Add(new JobItem())" class="btn-admin-ghost text-xs">+ Add Job</button>
                </div>

                <!-- Deliverables -->
                <div class="flex flex-col gap-4">
                    <div class="admin-section-label">Key Deliverables</div>
                    @for (int i = 0; i < _c.Deliverables.Count; i++)
                    {
                        var idx = i;
                        var d = _c.Deliverables[idx];
                        <div class="bg-[#13131f] border border-white/5 p-6 flex flex-col gap-4">
                            <div class="flex flex-col">
                                <label class="admin-label">Label (e.g. 01 — Editor)</label>
                                <InputText @bind-Value="d.Label" class="admin-input" />
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Title</label>
                                <InputText @bind-Value="d.Title" class="admin-input" />
                            </div>
                            <div class="flex flex-col">
                                <label class="admin-label">Description</label>
                                <InputTextArea @bind-Value="d.Desc" rows="2" class="admin-input" />
                            </div>
                            <button @onclick="() => _c.Deliverables.RemoveAt(idx)" class="btn-admin-red text-xs self-end">Remove</button>
                        </div>
                    }
                    <button @onclick="() => _c.Deliverables.Add(new DeliverableItem())" class="btn-admin-ghost text-xs">+ Add Deliverable</button>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-white/5 flex items-center gap-4">
                <button @onclick="SaveContent" class="btn-admin-green">Save Changes</button>
                <span class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest">Saved to server JSON</span>
            </div>
        }

        <!-- ── CONTACT ── -->
        @if (_activeSection == "contact")
        {
            <div class="mb-8">
                <h2 class="font-['Bebas_Neue'] text-5xl tracking-wide">Contact Section</h2>
                <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest mt-1">Edit contact details and links</p>
            </div>

            <div class="bg-[#13131f] border border-white/5 p-8 max-w-xl flex flex-col gap-5">
                <div class="flex flex-col"><label class="admin-label">Headline</label><InputText @bind-Value="_c.ContactTitle" class="admin-input" /></div>
                <div class="flex flex-col"><label class="admin-label">Subtext</label><InputTextArea @bind-Value="_c.ContactSub" rows="2" class="admin-input" /></div>
                <div class="flex flex-col"><label class="admin-label">Email</label><InputText @bind-Value="_c.ContactEmail" class="admin-input" /></div>
                <div class="flex flex-col"><label class="admin-label">LinkedIn URL</label><InputText @bind-Value="_c.ContactLinkedIn" class="admin-input" /></div>
                <div class="flex flex-col"><label class="admin-label">GitHub URL</label><InputText @bind-Value="_c.ContactGithub" class="admin-input" /></div>
                <div class="flex flex-col"><label class="admin-label">Resume PDF URL</label><InputText @bind-Value="_c.ContactResume" class="admin-input" /></div>
            </div>

            <div class="mt-10 pt-6 border-t border-white/5 flex items-center gap-4">
                <button @onclick="SaveContent" class="btn-admin-green">Save Changes</button>
