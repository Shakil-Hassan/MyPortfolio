@inherits LayoutComponentBase

<div class="min-h-screen bg-[#0a0a0f] text-[#e8e8f0] selection:bg-[#00ff88] selection:text-[#0a0a0f]">
    
    <div id="cursor" class="fixed w-3 h-3 bg-[#00ff88] rounded-full pointer-events-none z-[9999] mix-blend-difference -translate-x-1/2 -translate-y-1/2"></div>
    <div id="cursorRing" class="fixed w-10 h-10 border border-[#00ff88] opacity-40 rounded-full pointer-events-none z-[9998] -translate-x-1/2 -translate-y-1/2 transition-[width,height] duration-300"></div>
    
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4 backdrop-blur-md bg-[#0a0a0f]/80 border-b border-white/5 flex justify-between items-center">
        <div class="font-['Space_Mono'] text-[#00ff88] text-sm tracking-widest uppercase">
            SHAKIL<span>_</span>HASSAN<span class="blink">█</span>
        </div>
        
        <NavMenu />
    </nav>

    <main class="pt-20">
        @Body
    </main>

    <footer class="border-t border-white/5 mt-24 py-8 px-12 flex justify-between items-center bg-[#0a0a0f]">
        <p class="font-['Space_Mono'] text-[10px] text-[#6b6b8a] uppercase tracking-widest">
            © 2026 Game Developer Portfolio. Built with <span class="text-[#00ff88]">precision</span>.
        </p>
    </footer>
</div>